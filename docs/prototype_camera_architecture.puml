@startuml
title Outdoor Camera Prototype - Edge Streaming Layout

skinparam shadowing false
skinparam defaultTextAlignment center
skinparam packageStyle rectangle
skinparam linetype ortho

rectangle "IP65 Outdoor Enclosure (Top View)" as Box {
  together {
    rectangle "Front Face\n(Lens Hole)" as Front
    rectangle "Camera Module 3" as Camera
    rectangle "Raspberry Pi 5\n+ Active Cooler" as Pi
  }

  rectangle "PoE Splitter" as Splitter
  rectangle "Cable Gland\n(Ethernet Entry)" as Gland
}

rectangle "Vectis Agent" as Agent
cloud "Vectis Cloud" as Cloud

Front -down-> Camera
Camera -down-> Pi
Gland -up-> Splitter
Splitter -left-> Pi
Pi --> Agent : HTTP MPEG-TS stream
Agent --> Cloud : media relay\n+ structured events

@enduml
